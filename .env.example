# Copy this to .env and fill in your values
# .env is gitignored — never commit it

ANTHROPIC_API_KEY=sk-ant-...
NYT_API_KEY=your-nyt-key-here
GNEWS_API_KEY=your-gnews-key-here
RESEND_API_KEY=re_...
RECIPIENT_EMAIL=you@example.com
FROM_EMAIL="Daily Brief <digest@yourdomain.com>"

# Max articles passed to Claude for scoring (higher = more diversity, more cost)
# ~$0.025/run at 120, ~$0.05/run at 240. Default: 120
MAX_SCORE_CANDIDATES=120

# Optional — leave blank to disable feedback links
FEEDBACK_BASE_URL=https://your-worker.workers.dev

# Optional — Reddit OAuth (not required for anonymous read)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
